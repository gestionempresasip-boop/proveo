# ============================================================
# PROVEO — Variables de entorno
# Renombra este archivo a .env.local y rellena los valores
# ============================================================

# ---- SUPABASE ----
# Las encuentras en: tu proyecto Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---- EMAIL (Resend) ----
# Regístrate en resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@tudominio.com

# ---- WHATSAPP (Twilio) ----
# Regístrate en twilio.com → Console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+34XXXXXXXXX

# ---- APP ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- SEED (importación inicial de productos, /api/seed-products) ----
# Genera un valor propio (ej: openssl rand -hex 16). Sin esta variable
# el endpoint queda desactivado.
SEED_SECRET=
